// Secrets.example.xcconfig — committed template.
//
// Copy this file to Secrets.xcconfig (same directory) and fill in your
// Cloudflare OAuth client ID below. Secrets.xcconfig is git-ignored.
//
// CF_OAUTH_CLIENT_ID is the PUBLIC PKCE OAuth client id (not a secret) that the
// app registers with Cloudflare. It is injected into Info.plist at build time
// as CFOAuthClientID.

CF_OAUTH_CLIENT_ID = REPLACE_WITH_CLOUDFLARE_OAUTH_CLIENT_ID
